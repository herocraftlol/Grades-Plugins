# Fichier de base de donnees SQLite : DOIT etre exactement le meme fichier
# (meme chemin) que celui configure dans "sqlite.path" du plugin
# GradePlugin sur chacun de tes serveurs Paper. Cela ne fonctionne que si
# ce service Node et tes serveurs Paper tournent sur la MEME machine
# (ou un volume/partage reseau commun).
#   Windows : DB_PATH=C:/minecraft/shared-data/grades.db
#   Linux   : DB_PATH=/home/minecraft/shared-data/grades.db
DB_PATH=./grades.db

# Cle secrete Stripe (ou adapte routes/webhook.js a ton prestataire de paiement)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Cle utilisee pour proteger le panel admin (attribution manuelle / competitions)
ADMIN_API_KEY=change_moi_en_une_longue_chaine_aleatoire

# Port sur lequel ce micro-service boutique va ecouter
PORT=3000

# Adresse de TON SITE (celui qui contient index.html) : utilisee pour
# rediriger le joueur vers la section boutique de ton site apres paiement.
SITE_URL=https://monsite.fr

# URL PUBLIQUE de CE micro-service, telle que vue depuis l'exterieur via
# ton reverse-proxy (chemin /boutique sur le meme domaine que ton site).
# C'est cette URL que Stripe et le navigateur du client doivent pouvoir
# atteindre - PAS l'URL interne (http://127.0.0.1:3000).
SHOP_PUBLIC_URL=https://monsite.fr/boutique

# CORS : pas indispensable ici puisque site + boutique sont sur le meme
# domaine (reverse-proxy), mais laisse par securite/portabilite.
ORIGIN=https://monsite.fr
